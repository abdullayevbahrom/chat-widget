APP_NAME=Widget
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# Database (PostgreSQL)
# For Docker: DB_HOST=postgres, for local: DB_HOST=127.0.0.1
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=[MUST_SET_IN_ENV]
DB_USERNAME=[MUST_SET_IN_ENV]
DB_PASSWORD=[MUST_SET_IN_ENV]
DB_SSLMODE=verify-full
# DB_SSL_ROOT_CERT=/path/to/ca-cert.pem

# Session
# For Docker: SESSION_DRIVER=redis, for local: SESSION_DRIVER=file
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Queue
# For Docker: QUEUE_CONNECTION=redis, for local: QUEUE_CONNECTION=sync
QUEUE_CONNECTION=redis

# Cache
# For Docker: CACHE_STORE=redis, for local: CACHE_STORE=file
CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# Redis
# For Docker: REDIS_HOST=redis, for local: REDIS_HOST=127.0.0.1
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=[MUST_SET_IN_ENV]
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
