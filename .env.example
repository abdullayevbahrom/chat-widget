APP_NAME=Widget
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost
APP_CIPHER=AES-256-CBC

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error
LOG_JSON_FORMAT=true
LOG_DAILY_DAYS=30

# Database (PostgreSQL)
# For Docker: DB_HOST=postgres, for local: DB_HOST=127.0.0.1
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=[MUST_SET_IN_ENV]
DB_USERNAME=[MUST_SET_IN_ENV]
DB_PASSWORD=[MUST_SET_IN_ENV]
DB_SSLMODE=verify-full
# DB_SSL_ROOT_CERT=/path/to/ca-cert.pem

# Session
# For Docker: SESSION_DRIVER=redis, for local: SESSION_DRIVER=file
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local

# Queue
# For Docker: QUEUE_CONNECTION=redis, for local: QUEUE_CONNECTION=sync
QUEUE_CONNECTION=redis

# Cache
# For Docker: CACHE_STORE=redis, for local: CACHE_STORE=file
CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# Redis
# For Docker: REDIS_HOST=redis, for local: REDIS_HOST=127.0.0.1
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=[MUST_SET_IN_ENV]
REDIS_PORT=6379

# Trusted Proxies (REQUIRED in production)
# Set to the IP(s) of your load balancer or reverse proxy.
# WARNING: Do NOT use '*' in production — list specific proxy IPs only.
TRUSTED_PROXIES=

# Stateful Domains for Sanctum SPA authentication
STATEFUL_DOMAINS=localhost,localhost:3000

# Health Endpoint IP Whitelist (comma-separated)
# Leave empty to allow all IPs in development mode
# HEALTH_ALLOWED_IPS=

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Filament Admin
FILAMENT_PANEL_PATH=admin

# Super Admin
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=

# Telegram Bot API
TELEGRAM_BOT_API_BASE_URL=https://api.telegram.org/bot
TELEGRAM_ADMIN_USER_IDS=

# Laravel Reverb (WebSocket)
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=6001
REVERB_SCHEME=http
REVERB_SCALING_ENABLED=true
REVERB_ALLOWED_ORIGINS=http://localhost,http://localhost:3000

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Security Headers
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUB_DOMAINS=true
HSTS_PRELOAD=false

# Reverb WebSocket - Production Settings
# For production, set this to your domain (e.g., widget.marca.uz)
# REVERB_PUBLIC_HOST=widget.marca.uz
# REVERB_PUBLIC_PORT=443
# REVERB_USE_PROXY=true  # Set to true if using nginx proxy at /reverb
